static void final_test(void)
{
    printf("--- final_test ---\n");
    dll_t *p_dll = dll_create();

    int test1 = 1;
    dll_insert_tail(p_dll, &test1);
    int test2 = 2;
    dll_insert_tail(p_dll, &test2);
    int test3 = 3;
    dll_insert_head(p_dll, &test3);
    int test4 = 4;
    dll_insert_head(p_dll, &test4);

    dll_remove_head(p_dll);
    dll_remove_tail(p_dll);

    int test5 = 5;
    dll_insert_tail(p_dll, &test5);
    int test6 = 6;
    dll_insert_head(p_dll, &test6);

    dll_remove_head(p_dll);
    dll_remove_tail(p_dll);

    int test7 = 7;
    dll_insert_tail(p_dll, &test7);
    int test8 = 8;
    dll_insert_head(p_dll, &test8);

    dll_remove_head(p_dll);
    dll_remove_tail(p_dll);

    int test9 = 9;
    dll_insert_tail(p_dll, &test9);
    int test0 = 0;
    dll_insert_head(p_dll, &test0);

    dll_destroy(&p_dll, NULL);

    printf("PASS\n");
}

int main(void)
{
    test_create_destroy();
    test_insert_remove_head();
    test_insert_remove_tail();
    test_size();
    iter_test();
    final_test();

    printf("\nAll tests passed.\n");
    return 0;
}
